{
  "name": "doobar3000",
  "productName": "Doobar 3000",
  "version": "0.2.1",
  "description": "A native Windows music player: iTunes-simple, foobar2000-powerful.",
  "author": "Stan M",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "make-icon": "node scripts/make-icon.mjs",
    "make-test-audio": "node scripts/make-test-audio.mjs",
    "dist": "electron-vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.stanm.doobar3000",
    "productName": "Doobar 3000",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "portable"
    },
    "portable": {
      "artifactName": "Doobar3000-${version}-portable.exe"
    }
  },
  "dependencies": {
    "music-metadata": "^10.3.0",
    "music-tempo": "^1.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
